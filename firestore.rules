rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUnderwritingRole() {
      return signedIn() && (
        request.auth.token.role in ['Admin', 'Underwriter', 'RiskOfficer'] ||
        ('roles' in request.auth.token && request.auth.token.roles.hasAny(['Admin', 'Underwriter', 'RiskOfficer']))
      );
    }

    match /applications/{applicationId} {
      allow read: if signedIn();
      allow create, update: if hasUnderwritingRole();

      match /auditTraces/{traceId} {
        allow read: if signedIn();
        allow create: if false;
        allow update, delete: if false;
      }
    }
  }
}
